{
  "name": "@lens-designer/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron shell for Lens Designer (macOS v1.0).",
  "main": "dist/main/main.cjs",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsx scripts/build.ts",
    "build:watch": "tsx scripts/build.ts --watch",
    "dev": "tsx scripts/dev.ts",
    "package": "electron-builder --mac",
    "package:dir": "electron-builder --mac --dir",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lens-designer/bridge": "workspace:*",
    "@lens-designer/capture-addon": "workspace:*",
    "electron-store": "^10.0.1",
    "node-stream-zip": "^1.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
